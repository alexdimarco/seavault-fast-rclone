 function startBrowserHeartbeat(){
+  let eventStreamStarted = false;
+  if(window.EventSource){
+    try {
+      const es = new EventSource('/api/browser-session');
+      eventStreamStarted = true;
+      es.onopen = () => { try { appendLog('Browser session monitor connected', 'SeaVault will stop after this page closes.'); } catch(_) {} };
+      es.onerror = () => { try { appendLog('Browser session monitor warning', 'The browser session stream disconnected; heartbeat fallback remains active.', 'warning'); } catch(_) {} };
+      window.addEventListener('pagehide', () => { try { es.close(); } catch(_) {} });
+      window.addEventListener('beforeunload', () => { try { es.close(); } catch(_) {} });
+    } catch(err) {
+      try { appendLog('Browser session monitor unavailable', err && err.message ? err.message : String(err), 'warning'); } catch(_) {}
+    }
+  }
   const beat = () => {
     fetch('/api/browser-heartbeat', {method:'POST', keepalive:true, cache:'no-store'}).catch(err => {
