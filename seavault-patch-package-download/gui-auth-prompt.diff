+function renderGuiAuthStatus(cfg){
+  const box = $('guiAuthStatusBox');
+  if(!box) return;
+  const gui = cfg && cfg.gui ? cfg.gui : {};
+  const username = (gui.username || '').trim();
+  const configured = !!gui.passwordConfigured;
+  const active = !!(username && configured);
+  const cls = active ? 'status-open' : (username || configured ? 'status-warning' : '');
+  const pill = active ? 'active' : (username || configured ? 'incomplete' : 'off');
+  let detail = 'GUI login is off. Set both a username and a password, then save settings to enable the browser login prompt.';
+  if(active) detail = 'GUI login is active for user "' + username + '". Reloading the GUI should trigger the browser credential prompt.';
+  else if(username && !configured) detail = 'Username is set, but no GUI password is stored. Enter a password and save settings to enable login.';
+  else if(!username && configured) detail = 'A GUI password is marked as configured, but username is blank. Set a username or clear GUI login.';
+  box.innerHTML = '<div class="vault-card '+cls+'"><header><span class="vault-name">GUI login</span><span class="pill">'+pill+'</span></header><small>'+esc(detail)+'</small></div>';
+}
