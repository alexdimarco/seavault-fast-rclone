+func (s *Server) requireGUIAuth(w http.ResponseWriter, r *http.Request) bool {
+	cfg := s.currentConfig()
+	username := strings.TrimSpace(cfg.GUI.Username)
+	if username == "" || !cfg.GUI.PasswordConfigured {
+		return true
+	}
+	providedUser, providedPassword, ok := r.BasicAuth()
+	if !ok || subtle.ConstantTimeCompare([]byte(providedUser), []byte(username)) != 1 {
+		s.requestGUIAuth(w)
+		return false
+	}
+	expectedPassword, err := keychain.Get("seavault-gui-http-auth")
+	if err != nil || expectedPassword == "" {
+		w.Header().Set("Content-Type", "text/plain; charset=utf-8")
+		w.WriteHeader(http.StatusServiceUnavailable)
+		_, _ = io.WriteString(w, "SeaVault GUI login is configured, but the GUI password could not be read from the OS keychain. Open settings from a trusted local session after restoring keychain access, or clear the saved GUI username/password from the SeaVault app configuration.\n")
+		return false
+	}
+	if subtle.ConstantTimeCompare([]byte(providedPassword), []byte(expectedPassword)) != 1 {
+		s.requestGUIAuth(w)
+		return false
+	}
+	return true
+}
+
+func (s *Server) requestGUIAuth(w http.ResponseWriter) {
+	w.Header().Set("WWW-Authenticate", `Basic realm="SeaVault GUI", charset="UTF-8"`)
+	http.Error(w, "SeaVault GUI login required", http.StatusUnauthorized)
+}
